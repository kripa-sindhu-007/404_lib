{
  "name": "@kripa006/404-ui",
  "version": "0.1.0",
  "description": "Beautiful animated 404 page components for React, Vue, and vanilla JavaScript.",
  "author": "Kripa Sindhu <sindhukripa007@gmail.com>",
  "license": "MIT",
  "homepage": "https://kripa-sindhu-007.github.io/404_lib",
  "bugs": {
    "url": "https://github.com/kripa-sindhu-007/404_lib/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kripa-sindhu-007/404_lib.git",
    "directory": "packages/404-ui"
  },
  "keywords": [
    "404",
    "error-page",
    "not-found",
    "react",
    "vue",
    "vue3",
    "vanilla",
    "vanilla-js",
    "javascript",
    "typescript",
    "404-page",
    "animated",
    "components",
    "tailwind",
    "tailwindcss",
    "astro"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react/index.d.ts",
        "default": "./dist/react/index.js"
      },
      "require": {
        "types": "./dist/react/index.d.cts",
        "default": "./dist/react/index.cjs"
      }
    },
    "./vue": {
      "import": {
        "types": "./dist/vue/index.d.ts",
        "default": "./dist/vue/index.js"
      },
      "require": {
        "types": "./dist/vue/index.d.cts",
        "default": "./dist/vue/index.cjs"
      }
    },
    "./vanilla": {
      "import": {
        "types": "./dist/vanilla/index.d.ts",
        "default": "./dist/vanilla/index.js"
      },
      "require": {
        "types": "./dist/vanilla/index.d.cts",
        "default": "./dist/vanilla/index.cjs"
      }
    },
    "./theme": {
      "import": {
        "types": "./dist/theme.d.ts",
        "default": "./dist/theme.js"
      },
      "require": {
        "types": "./dist/theme.d.cts",
        "default": "./dist/theme.cjs"
      }
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm build:css && pnpm build:js",
    "build:css": "tailwindcss -i src/core/styles/index.css -o dist/styles.css --minify",
    "build:js": "tsup",
    "dev": "pnpm build:css && tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "size": "size-limit",
    "clean": "rimraf dist"
  },
  "size-limit": [
    {
      "name": "react entry (gzip)",
      "path": "dist/react/index.js",
      "gzip": true,
      "limit": "11 KB"
    },
    {
      "name": "vue entry (gzip)",
      "path": "dist/vue/index.js",
      "gzip": true,
      "limit": "11 KB"
    },
    {
      "name": "vanilla entry (gzip)",
      "path": "dist/vanilla/index.js",
      "gzip": true,
      "limit": "12 KB"
    },
    {
      "name": "styles.css (gzip)",
      "path": "dist/styles.css",
      "gzip": true,
      "limit": "11 KB"
    }
  ],
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "vue": ">=3.4.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^3.0.0",
    "@vue/test-utils": "^2.4.0",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rimraf": "^6.0.1",
    "size-limit": "^11.1.6",
    "@size-limit/preset-small-lib": "^11.1.6",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
