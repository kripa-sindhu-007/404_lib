---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Space404, Ocean404, Glitch404 } from "@kripa006/404-ui/react";

// Template data
const templates = [
  {
    id: "space",
    name: "Apollo 404",
    description: "An Apollo-era mission-control console — CRT phosphor, telemetry rails, orbital diagnostic, and a handful of hidden easter eggs",
    tags: ["animated", "dark", "mission-control"],
    preview: "📡",
  },
  {
    id: "ocean",
    name: "Ocean 404",
    description: "A bioluminescent deep-sea drift with rising bubbles, a sonar ping, and a few hidden easter eggs",
    tags: ["animated", "dark", "ocean"],
    preview: "🪼",
    name: "Apollo 404",
    description: "An Apollo-era mission-control console — CRT phosphor, telemetry rails, orbital diagnostic, and a handful of hidden easter eggs",
    tags: ["animated", "dark", "mission-control"],
    preview: "📡",
  },
  {
    id: "ocean",
    name: "Ocean 404",
    description: "A bioluminescent deep-sea drift with rising bubbles, a sonar ping, and a few hidden easter eggs",
    tags: ["animated", "dark", "ocean"],
    preview: "🪼",
  },
  {
    id: "glitch",
    name: "Glitch 404",
    description: "A corrupted-broadcast page with chromatic aberration, scanlines, sync-bar tear, and a 'NO SIGNAL' callout. Type GLITCH for a meltdown.",
    tags: ["animated", "dark", "retro", "cyberpunk"],
    preview: "📺",
  },
  {
    id: "forest",
    name: "Forest 404",
    description: "A serene forest scene with falling leaves",
    tags: ["animated", "nature", "green"],
    preview: "🌲",
    comingSoon: true,
  },
];
---

<BaseLayout
  title="404 Template Gallery | 404-UI"
  description="Explore the 404-UI gallery of animated not-found page templates for React, Vue, and vanilla JavaScript applications."
  keywords="404 template gallery, animated 404 templates, React not found page, Vue not found page, JavaScript 404 template"
>
  <section class="py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div>
        <p class="eyebrow">
          <span class="eyebrow-dot" aria-hidden="true"></span>
          The library
        </p>
        <h1 class="mt-4 text-5xl font-semibold tracking-[-0.01em] text-balance sm:text-6xl">
          Templates,
          <span class="font-display text-paper-muted">one at a time.</span>
      <div>
        <p class="eyebrow">
          <span class="eyebrow-dot" aria-hidden="true"></span>
          The library
        </p>
        <h1 class="mt-4 text-5xl font-semibold tracking-[-0.01em] text-balance sm:text-6xl">
          Templates,
          <span class="font-display text-paper-muted">one at a time.</span>
        </h1>
        <p class="mt-5 max-w-2xl text-paper-muted text-pretty">
          Every 404 page here is handcrafted and animated. Click a preview to
          see it fullscreen, or copy the code for your framework of choice.
          More templates are on the way — contributions welcome.
        <p class="mt-5 max-w-2xl text-paper-muted text-pretty">
          Every 404 page here is handcrafted and animated. Click a preview to
          see it fullscreen, or copy the code for your framework of choice.
          More templates are on the way — contributions welcome.
        </p>
      </div>

      <!-- Templates Grid -->
      <div class="mt-12 grid gap-8 md:grid-cols-2">
        {templates.map((template) => (
          <div class="card card-hover overflow-hidden">
            <!-- Preview -->
            <div class="preview-surface h-[240px] sm:h-[280px] md:h-[320px]" style="background: rgb(17 19 17);">
            <div class="preview-surface h-[240px] sm:h-[280px] md:h-[320px]" style="background: rgb(17 19 17);">
              {template.comingSoon ? (
                <div class="flex h-full items-center justify-center">
                  <div class="text-center">
                    <span class="text-6xl">{template.preview}</span>
                    <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.3em] text-paper-dim">
                    <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.3em] text-paper-dim">
                      Coming Soon
                    </p>
                  </div>
                </div>
              ) : template.id === "ocean" ? (
                <Ocean404
                  client:only="react"
                  title="404"
                  eyebrow="Signal lost · 11,034m"
                  subtitle="You've drifted too deep."
                  buttonText="Return to surface"
                  bubbleCount={18}
                />
              ) : template.id === "glitch" ? (
                <Glitch404
                  client:only="react"
                  title="404"
                  eyebrow="Transmission interrupted"
                  headline="Page corrupted"
                  subtitle="The signal carrying this page has been lost."
                  buttonText="Retune"
                  channelId="04"
                />
              ) : (
                <Space404
                  client:only="react"
                  title="404"
                  eyebrow="SIGNAL LOST"
                  headline="OFF-NOMINAL TRAJECTORY"
                  subtitle="The page you requested drifted outside the nominal envelope."
                  buttonText="RE-VECTOR"
                  missionId="APOLLO · LM-404"
                />
              )}
            </div>

            <!-- Info -->
            <div class="p-6">
              <div class="flex items-start justify-between">
                <div>
                  <h3 class="font-space text-xl font-semibold text-gray-900 dark:text-white">
                    {template.name}
                  </h3>
                  <p class="mt-2 text-gray-600 dark:text-gray-400">
                    {template.description}
                  </p>
                </div>
              </div>

              <!-- Tags -->
              <div class="mt-4 flex flex-wrap gap-2">
                {template.tags.map((tag) => (
                  <span class="rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-600 dark:bg-gray-800 dark:text-gray-400">
                    {tag}
                  </span>
                ))}
              </div>

              <!-- Actions -->
              <div class="mt-6 flex gap-3">
                <button
                  class="btn btn-primary flex-1"
                  data-template={template.id}
                  disabled={template.comingSoon}
                >
                  {template.comingSoon ? "Coming Soon" : "Copy Code"}
                </button>
                <a
                  href={template.comingSoon ? "#" : `/404_lib/demo/${template.id}`}
                  target={template.comingSoon ? "_self" : "_blank"}
                  class={`btn btn-secondary text-center ${template.comingSoon ? "cursor-not-allowed opacity-50" : ""}`}
                >
                  Preview
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Full Screen Preview Modal -->
  <div id="preview-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 p-4">
    <button id="close-modal" class="absolute right-4 top-4 text-white hover:text-gray-300">
      <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    <div id="modal-content" class="h-full w-full max-w-6xl overflow-hidden rounded-2xl"></div>
  </div>

  <!-- Code Modal -->
  <div id="code-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 p-4">
    <div class="w-full max-w-3xl rounded-2xl bg-white p-6 dark:bg-gray-900">
      <div class="flex items-center justify-between mb-4">
        <h3 class="font-space text-xl font-semibold text-gray-900 dark:text-white">
          Copy Code
        </h3>
        <button id="close-code-modal" class="text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-white">
          <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
        <p class="font-mono text-[10px] uppercase tracking-[0.3em] text-paper-dim">
          Framework
        </p>
        <div class="framework-toggle" id="code-modal-framework">
          <button type="button" class="framework-toggle-btn framework-toggle-btn-active" data-framework="react">
            React
          </button>
          <button type="button" class="framework-toggle-btn framework-toggle-btn-inactive" data-framework="vue">
            Vue
          </button>
          <button type="button" class="framework-toggle-btn framework-toggle-btn-inactive" data-framework="vanilla">
            Vanilla
          </button>
        </div>
      </div>
      <pre id="code-content" class="code-block max-h-96 overflow-auto"></pre>
      <button id="copy-code" class="btn btn-primary mt-4 w-full">
        Copy to Clipboard
      </button>
    </div>
  </div>
</BaseLayout>

<script is:inline>
  // Framework toggle (lives inside the code modal)
  let currentFramework = 'react';
  let currentTemplateId = null;
  const frameworkButtons = document.querySelectorAll('#code-modal-framework [data-framework]');
  frameworkButtons.forEach(function(btn) {
    btn.addEventListener('click', function() {
      frameworkButtons.forEach(function(b) {
        b.classList.remove('framework-toggle-btn-active');
        b.classList.add('framework-toggle-btn-inactive');
      });
      btn.classList.remove('framework-toggle-btn-inactive');
      btn.classList.add('framework-toggle-btn-active');
      currentFramework = btn.dataset.framework || 'react';
      renderCodeSnippet();
    });
  });

  function renderCodeSnippet() {
    if (!currentTemplateId || !codeSnippets[currentTemplateId]) return;
    const code = codeSnippets[currentTemplateId][currentFramework];
    const codeContent = document.getElementById('code-content');
    if (codeContent) {
      codeContent.textContent = code;
    }
  }

  // Code snippets
  const codeSnippets = {
    space: {
      react:
        "import { Space404 } from '@kripa006/404-ui/react';\n\nfunction NotFoundPage() {\n  return (\n    <Space404\n      title=\"404\"\n      eyebrow=\"SIGNAL LOST · UPLINK DEGRADED\"\n      headline=\"OFF-NOMINAL TRAJECTORY DETECTED\"\n      subtitle=\"The page you requested has drifted outside the nominal envelope.\"\n      buttonText=\"RE-VECTOR TO BASE\"\n      missionId=\"APOLLO · LM-404\"\n      showOrbit={true}\n      onButtonClick={() => window.location.href = '/'}\n    />\n  );\n}\n\nexport default NotFoundPage;",
      vue:
        "<script setup>\nimport { Space404 } from '@kripa006/404-ui/vue';\n\nfunction handleClick() {\n  window.location.href = '/';\n}\n<\\/script>\n\n<template>\n  <Space404\n    title=\"404\"\n    eyebrow=\"SIGNAL LOST · UPLINK DEGRADED\"\n    headline=\"OFF-NOMINAL TRAJECTORY DETECTED\"\n    subtitle=\"The page you requested has drifted outside the nominal envelope.\"\n    button-text=\"RE-VECTOR TO BASE\"\n    mission-id=\"APOLLO · LM-404\"\n    :show-orbit=\"true\"\n    @button-click=\"handleClick\"\n  />\n</template>",
      vanilla:
        "import { createSpace404 } from '@kripa006/404-ui/vanilla';\n\nconst container = document.getElementById('app');\n\nconst space404 = createSpace404(container, {\n  title: '404',\n  eyebrow: 'SIGNAL LOST · UPLINK DEGRADED',\n  headline: 'OFF-NOMINAL TRAJECTORY DETECTED',\n  subtitle: 'The page you requested has drifted outside the nominal envelope.',\n  buttonText: 'RE-VECTOR TO BASE',\n  missionId: 'APOLLO · LM-404',\n  showOrbit: true,\n  onButtonClick: () => {\n    window.location.href = '/';\n  }\n});\n\n// Cleanup when needed\n// space404.destroy();",
    },
    ocean: {
      react:
        "import { Ocean404 } from '@kripa006/404-ui/react';\n\nfunction NotFoundPage() {\n  return (\n    <Ocean404\n      title=\"404\"\n      eyebrow=\"Signal lost · 11,034m\"\n      subtitle=\"You've drifted too deep. The surface is waiting.\"\n      buttonText=\"Return to surface\"\n      bubbleCount={28}\n      showJellyfish={true}\n      onButtonClick={() => window.location.href = '/'}\n    />\n  );\n}\n\nexport default NotFoundPage;",
      vue:
        "<script setup>\nimport { Ocean404 } from '@kripa006/404-ui/vue';\n\nfunction handleClick() {\n  window.location.href = '/';\n}\n<\\/script>\n\n<template>\n  <Ocean404\n    title=\"404\"\n    eyebrow=\"Signal lost · 11,034m\"\n    subtitle=\"You've drifted too deep. The surface is waiting.\"\n    button-text=\"Return to surface\"\n    :bubble-count=\"28\"\n    :show-jellyfish=\"true\"\n    @button-click=\"handleClick\"\n  />\n</template>",
      vanilla:
        "import { createOcean404 } from '@kripa006/404-ui/vanilla';\n\nconst container = document.getElementById('app');\n\nconst ocean404 = createOcean404(container, {\n  title: '404',\n  eyebrow: 'Signal lost · 11,034m',\n  subtitle: \"You've drifted too deep. The surface is waiting.\",\n  buttonText: 'Return to surface',\n  bubbleCount: 28,\n  showJellyfish: true,\n  onButtonClick: () => {\n    window.location.href = '/';\n  }\n});\n\n// Cleanup when needed\n// ocean404.destroy();",
    },
    glitch: {
      react:
        "import { Glitch404 } from '@kripa006/404-ui/react';\n\nfunction NotFoundPage() {\n  return (\n    <Glitch404\n      title=\"404\"\n      eyebrow=\"Transmission interrupted\"\n      headline=\"Page corrupted\"\n      subtitle=\"The signal carrying this page has been lost in transit. Retune.\"\n      buttonText=\"Retune\"\n      channelId=\"04\"\n      showNoSignal={true}\n      onButtonClick={() => window.location.href = '/'}\n    />\n  );\n}\n\nexport default NotFoundPage;",
      vue:
        "<script setup>\nimport { Glitch404 } from '@kripa006/404-ui/vue';\n\nfunction handleClick() {\n  window.location.href = '/';\n}\n<\\/script>\n\n<template>\n  <Glitch404\n    title=\"404\"\n    eyebrow=\"Transmission interrupted\"\n    headline=\"Page corrupted\"\n    subtitle=\"The signal carrying this page has been lost in transit. Retune.\"\n    button-text=\"Retune\"\n    channel-id=\"04\"\n    :show-no-signal=\"true\"\n    @button-click=\"handleClick\"\n  />\n</template>",
      vanilla:
        "import { createGlitch404 } from '@kripa006/404-ui/vanilla';\n\nconst container = document.getElementById('app');\n\nconst glitch404 = createGlitch404(container, {\n  title: '404',\n  eyebrow: 'Transmission interrupted',\n  headline: 'Page corrupted',\n  subtitle: 'The signal carrying this page has been lost in transit. Retune.',\n  buttonText: 'Retune',\n  channelId: '04',\n  showNoSignal: true,\n  onButtonClick: () => {\n    window.location.href = '/';\n  }\n});\n\n// Cleanup when needed\n// glitch404.destroy();",
    },
  };

  // Copy code button
  document.querySelectorAll('[data-template]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      const templateId = btn.dataset.template;
      if (!templateId || !codeSnippets[templateId]) return;

      currentTemplateId = templateId;
      const codeModal = document.getElementById('code-modal');
      if (codeModal) {
        renderCodeSnippet();
        codeModal.classList.remove('hidden');
        codeModal.classList.add('flex');
      }
    });
  });

  // Close code modal
  const closeCodeModal = document.getElementById('close-code-modal');
  if (closeCodeModal) {
    closeCodeModal.addEventListener('click', function() {
      const codeModal = document.getElementById('code-modal');
      if (codeModal) {
        codeModal.classList.add('hidden');
        codeModal.classList.remove('flex');
      }
    });
  }

  // Copy to clipboard
  const copyCode = document.getElementById('copy-code');
  if (copyCode) {
    copyCode.addEventListener('click', function() {
      const codeContent = document.getElementById('code-content');
      const code = codeContent ? codeContent.textContent : '';
      if (code) {
        navigator.clipboard.writeText(code).then(function() {
          alert('Code copied to clipboard!');
        });
      }
    });
  }

  // Preview modal
  document.querySelectorAll('[data-preview]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      const templateId = btn.dataset.preview;
      const preview = document.getElementById('preview-' + templateId);
      const modal = document.getElementById('preview-modal');
      const content = document.getElementById('modal-content');
      
      if (preview && modal && content) {
        content.innerHTML = preview.outerHTML;
        modal.classList.remove('hidden');
        modal.classList.add('flex');
      }
    });
  });

  // Close preview modal
  const closeModal = document.getElementById('close-modal');
  if (closeModal) {
    closeModal.addEventListener('click', function() {
      const modal = document.getElementById('preview-modal');
      if (modal) {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
      }
    });
  }

  // Close on escape
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      const previewModal = document.getElementById('preview-modal');
      const codeModal = document.getElementById('code-modal');
      if (previewModal) {
        previewModal.classList.add('hidden');
        previewModal.classList.remove('flex');
      }
      if (codeModal) {
        codeModal.classList.add('hidden');
        codeModal.classList.remove('flex');
      }
    }
  });
</script>
