<script is:inline>
  // Install-command copy (hero + install section)
  async function copyInstall(stateEl) {
    try {
      await navigator.clipboard.writeText("npm install @kripa006/404-ui");
      if (stateEl) {
        const prev = stateEl.textContent;
        stateEl.textContent = "✓ copied";
        stateEl.style.color = "rgb(124 255 74)";
        setTimeout(() => {
          stateEl.textContent = prev;
          stateEl.style.color = "";
        }, 1400);
      }
    } catch {
      /* clipboard unavailable */
    }
  }

  const heroCopy = document.getElementById("hero-copy");
  const heroCopyState = document.getElementById("hero-copy-state");
  heroCopy?.addEventListener("click", () => copyInstall(heroCopyState));

  // Hero featured-template switcher
  const heroFeatures = {
    apollo: {
      label: "Apollo404",
      file: "Apollo404.tsx",
      caption: "01 — Apollo · mission control",
      hint: "try ⇧ · type APOLLO",
    },
    ocean: {
      label: "Ocean404",
      file: "Ocean404.tsx",
      caption: "02 — Ocean · deep sea",
      hint: "click bubbles · ↑↑↓↓",
    },
    glitch: {
      label: "Glitch404",
      file: "Glitch404.tsx",
      caption: "03 — Glitch · broken broadcast",
      hint: "type GLITCH · hold to densify",
    },
  };
  const heroPanes = {
    apollo: document.getElementById("hero-pane-apollo"),
    ocean: document.getElementById("hero-pane-ocean"),
    glitch: document.getElementById("hero-pane-glitch"),
  };
  const heroLabel = document.getElementById("hero-feature-label");
  const heroFile = document.getElementById("hero-feature-file");
  const heroCaption = document.getElementById("hero-feature-caption");
  const heroHint = document.getElementById("hero-feature-hint");

  document.querySelectorAll("[data-feature]").forEach((thumb) => {
    if (thumb.disabled) return;
    thumb.addEventListener("click", () => {
      const key = thumb.dataset.feature;
      const meta = heroFeatures[key];
      if (!meta) return;

      // toggle thumb states
      document.querySelectorAll("[data-feature]").forEach((t) => {
        t.classList.remove("hero-thumb-active");
        t.setAttribute("aria-selected", "false");
      });
      thumb.classList.add("hero-thumb-active");
      thumb.setAttribute("aria-selected", "true");

      // toggle panes
      Object.entries(heroPanes).forEach(([k, el]) => {
        if (!el) return;
        el.classList.toggle("hidden", k !== key);
      });

      if (heroLabel) heroLabel.textContent = meta.label;
      if (heroFile) heroFile.textContent = meta.file;
      if (heroCaption) heroCaption.textContent = meta.caption;
      if (heroHint) heroHint.textContent = meta.hint;
    });
  });

  const installCopy = document.getElementById("install-copy");
  installCopy?.addEventListener("click", () => copyInstall(installCopy));

  // Framework tabs
  const tabs = document.querySelectorAll("#install-tabs [data-framework]");
  const panes = {
    react: document.getElementById("install-react"),
    vue: document.getElementById("install-vue"),
    vanilla: document.getElementById("install-vanilla"),
  };

  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      const key = tab.dataset.framework;

      tabs.forEach((t) => {
        t.classList.remove("framework-toggle-btn-active");
        t.classList.add("framework-toggle-btn-inactive");
        t.setAttribute("aria-selected", "false");
      });
      tab.classList.remove("framework-toggle-btn-inactive");
      tab.classList.add("framework-toggle-btn-active");
      tab.setAttribute("aria-selected", "true");

      Object.entries(panes).forEach(([k, el]) => {
        if (!el) return;
        if (k === key) {
          el.classList.remove("hidden");
          el.classList.add("block");
        } else {
          el.classList.add("hidden");
          el.classList.remove("block");
        }
      });
    });
  });
</script>
