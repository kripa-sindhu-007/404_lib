---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Glitch404 } from "@kripa006/404-ui/react";
---

<BaseLayout
  title="Glitch 404 Demo | 404-UI"
  description="Preview the Glitch 404 corrupted-broadcast not-found page from 404-UI, available for React, Vue, and vanilla JavaScript."
  keywords="Glitch 404 demo, cyberpunk 404, CRT 404, broken signal 404, retro 404, React 404 demo, Vue 404 demo, 404-UI template"
>
  <div style="height: calc(100vh - 64px);">
    <Glitch404
      client:only="react"
      title="404"
      eyebrow="Transmission interrupted"
      headline="Page corrupted"
      subtitle="The signal carrying this page has been lost in transit. Retune."
      buttonText="Retune"
      channelId="04"
      onButtonClick={() => window.location.href = '/404_lib/'}
    />
  </div>
</BaseLayout>
