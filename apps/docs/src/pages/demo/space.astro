---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Space404 } from "@kripa006/404-ui/react";
---

<BaseLayout
  title="Apollo 404 Demo | 404-UI"
  description="Preview the Apollo 404 mission-control not-found page from 404-UI — CRT phosphor console with telemetry, orbital diagnostic, and hidden easter eggs."
  keywords="Apollo 404 demo, mission control 404, CRT 404 page, retro space 404, React 404 demo, Vue 404 demo, 404-UI template"
>
  <div style="height: calc(100vh - 64px);">
    <Space404
      client:only="react"
      title="404"
      eyebrow="SIGNAL LOST · UPLINK DEGRADED"
      headline="OFF-NOMINAL TRAJECTORY DETECTED"
      subtitle="The page you requested has drifted outside the nominal envelope. Re-establishing uplink with base."
      buttonText="RE-VECTOR TO BASE"
      missionId="APOLLO · LM-404"
      onButtonClick={() => window.location.href = '/404_lib/'}
    />
  </div>
</BaseLayout>
