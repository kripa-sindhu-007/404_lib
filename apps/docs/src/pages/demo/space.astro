---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Space404 } from "@kripa006/404-ui/react";
---

<BaseLayout
  title="Space 404 Demo | 404-UI"
  description="Preview the Space 404 animated not-found page from 404-UI, available for React, Vue, and vanilla JavaScript."
  keywords="Space 404 demo, animated space 404, React 404 demo, Vue 404 demo, 404-UI template"
>
  <div style="height: calc(100vh - 64px);">
    <Space404
      client:only="react"
      title="404"
      subtitle="Lost in space..."
      buttonText="Go Home"
      onButtonClick={() => window.location.href = '/404_lib/'}
    />
  </div>
</BaseLayout>
