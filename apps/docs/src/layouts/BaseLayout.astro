---
export interface Props {
  title?: string;
  description?: string;
  keywords?: string;
}

const {
  title = "404-UI — design-forward 404 pages for React, Vue, and JavaScript",
  description = "A small library of carefully designed, animated 404 error pages. Drop them into any React, Vue, or Vanilla app.",
  keywords = "404 page, not found page, error page, React 404 component, Vue 404 component, animated 404, TypeScript components, Tailwind CSS",
} = Astro.props;

const siteUrl = Astro.site ?? new URL("https://kripa-sindhu-007.github.io");
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const faviconPath = `${base}/favicon.svg`;
const homePath = `${base}/`;
const galleryPath = `${base}/gallery`;
const themingPath = `${base}/theming`;

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const isGallery = currentPath.startsWith(`${base}/gallery`);
const isTheming = currentPath.startsWith(`${base}/theming`);
const isHome = !isGallery && !isTheming;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Kripa Sindhu" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#0a0b09" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />

    <link rel="icon" type="image/svg+xml" href={faviconPath} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="404-UI" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-ink text-paper">
    <!-- Nav -->
    <nav class="sticky top-0 z-50 backdrop-blur-lg" style="background: rgb(10 11 9 / 0.72); border-bottom: 1px solid rgb(245 244 240 / 0.08);">
      <div class="mx-auto flex h-14 max-w-6xl items-center justify-between px-4 sm:px-6 lg:px-8">
        <div class="flex items-center gap-8">
          <a href={homePath} class="group flex items-center gap-2.5" aria-label="404-UI home">
            <span
              aria-hidden="true"
              class="inline-flex h-6 w-6 items-center justify-center font-mono text-[10px] font-bold leading-none"
              style="background: rgb(124 255 74); color: rgb(10 11 9); letter-spacing: -0.02em;"
            >
              404
            </span>
            <span class="font-mono text-[13px] font-semibold tracking-[0.08em]">
              UI
            </span>
            <span class="hidden font-mono text-[10px] text-paper-dim sm:inline-block" style="letter-spacing: 0.25em;">
              v0.1 · MIT
            </span>
          </a>

          <div class="hidden items-center gap-6 md:flex">
            <a
              href={homePath}
              class={`nav-link ${isHome ? "nav-link-active" : ""}`}
            >
              Overview
            </a>
            <a
              href={galleryPath}
              class={`nav-link ${isGallery ? "nav-link-active" : ""}`}
            >
              Templates
            </a>
            <a
              href={themingPath}
              class={`nav-link ${isTheming ? "nav-link-active" : ""}`}
            >
              Theming
            </a>
            <a
              href="https://www.npmjs.com/package/@kripa006/404-ui"
              target="_blank"
              rel="noopener"
              class="nav-link"
            >
              npm
            </a>
            <a
              href="https://github.com/kripa-sindhu-007/404_lib"
              target="_blank"
              rel="noopener"
              class="nav-link"
            >
              GitHub
            </a>
          </div>
        </div>

        <div class="flex items-center gap-3">
          <button
            id="copy-install-nav"
            type="button"
            class="hidden items-center gap-2 px-3 py-1.5 font-mono text-[11px] text-paper-muted transition-colors hover:text-paper lg:inline-flex"
            style="border: 1px solid rgb(245 244 240 / 0.12); background: rgb(245 244 240 / 0.03);"
            title="Copy install command"
          >
            <span class="text-accent">$</span>
            <span>npm i @kripa006/404-ui</span>
            <span class="kbd ml-1">⌘C</span>
          </button>
          <a
            href="https://github.com/kripa-sindhu-007/404_lib"
            target="_blank"
            rel="noopener"
            class="btn btn-primary hidden sm:inline-flex"
          >
            Get started
          </a>
          <button
            id="mobile-menu-toggle"
            type="button"
            class="inline-flex h-9 w-9 items-center justify-center md:hidden"
            aria-expanded="false"
            aria-controls="mobile-menu"
            aria-label="Toggle navigation menu"
            style="border: 1px solid rgb(245 244 240 / 0.12); background: rgb(245 244 240 / 0.03);"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="square" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile menu panel -->
      <div
        id="mobile-menu"
        class="hidden border-t border-paper-faint md:hidden"
        style="background: rgb(10 11 9 / 0.96);"
      >
        <ul class="mx-auto flex max-w-6xl flex-col gap-1 px-4 py-3 sm:px-6">
          <li>
            <a href={homePath} class="block py-2 text-sm text-paper-muted hover:text-paper">
              <span class="font-mono text-[10px] uppercase tracking-[0.3em] text-paper-dim">01</span>
              &nbsp;&nbsp;Overview
            </a>
          </li>
          <li>
            <a href={galleryPath} class="block py-2 text-sm text-paper-muted hover:text-paper">
              <span class="font-mono text-[10px] uppercase tracking-[0.3em] text-paper-dim">02</span>
              &nbsp;&nbsp;Templates
            </a>
          </li>
          <li>
            <a href={themingPath} class="block py-2 text-sm text-paper-muted hover:text-paper">
              <span class="font-mono text-[10px] uppercase tracking-[0.3em] text-paper-dim">03</span>
              &nbsp;&nbsp;Theming
            </a>
          </li>
          <li>
            <a href="https://www.npmjs.com/package/@kripa006/404-ui" target="_blank" rel="noopener" class="block py-2 text-sm text-paper-muted hover:text-paper">
              <span class="font-mono text-[10px] uppercase tracking-[0.3em] text-paper-dim">04</span>
              &nbsp;&nbsp;npm
            </a>
          </li>
          <li>
            <a href="https://github.com/kripa-sindhu-007/404_lib" target="_blank" rel="noopener" class="block py-2 text-sm text-paper-muted hover:text-paper">
              <span class="font-mono text-[10px] uppercase tracking-[0.3em] text-paper-dim">05</span>
              &nbsp;&nbsp;GitHub
            </a>
          </li>
          <li class="mt-2 flex items-center gap-2 rounded-none px-3 py-2 font-mono text-[11px] text-paper-muted" style="border: 1px solid rgb(245 244 240 / 0.12); background: rgb(245 244 240 / 0.03);">
            <span class="text-accent">$</span>
            <span class="truncate">npm i @kripa006/404-ui</span>
          </li>
        </ul>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="mt-24 border-t border-paper-faint">
      <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
        <div class="grid gap-10 md:grid-cols-4">
          <div class="md:col-span-1">
            <div class="flex items-center gap-2.5">
              <span
                aria-hidden="true"
                class="inline-flex h-6 w-6 items-center justify-center font-mono text-[10px] font-bold leading-none"
                style="background: rgb(124 255 74); color: rgb(10 11 9);"
              >
                404
              </span>
              <span class="font-mono text-[13px] font-semibold tracking-[0.08em]">UI</span>
            </div>
            <p class="mt-4 max-w-xs text-sm text-paper-muted text-pretty">
              Small library of design-forward 404 pages for modern apps.
              Handcrafted, not generated.
            </p>
          </div>

          <div>
            <h4 class="eyebrow mb-4">Product</h4>
            <ul class="flex flex-col gap-2 text-sm">
              <li><a href={homePath} class="link-arrow">Overview</a></li>
              <li><a href={galleryPath} class="link-arrow">Templates</a></li>
              <li><a href={themingPath} class="link-arrow">Theming</a></li>
              <li><a href={`${base}/demo/space`} class="link-arrow">Apollo 404</a></li>
              <li><a href={`${base}/demo/ocean`} class="link-arrow">Ocean 404</a></li>
            </ul>
          </div>

          <div>
            <h4 class="eyebrow mb-4">Open source</h4>
            <ul class="flex flex-col gap-2 text-sm">
              <li>
                <a href="https://github.com/kripa-sindhu-007/404_lib" target="_blank" rel="noopener" class="link-arrow">
                  GitHub repo
                </a>
              </li>
              <li>
                <a href="https://github.com/kripa-sindhu-007/404_lib/issues" target="_blank" rel="noopener" class="link-arrow">
                  Issues
                </a>
              </li>
              <li>
                <a href="https://github.com/kripa-sindhu-007/404_lib/blob/main/CONTRIBUTING.md" target="_blank" rel="noopener" class="link-arrow">
                  Contributing
                </a>
              </li>
              <li>
                <a href="https://github.com/kripa-sindhu-007/404_lib/blob/main/SECURITY.md" target="_blank" rel="noopener" class="link-arrow">
                  Security
                </a>
              </li>
            </ul>
          </div>

          <div>
            <h4 class="eyebrow mb-4">Install</h4>
            <ul class="flex flex-col gap-2 text-sm">
              <li>
                <a href="https://www.npmjs.com/package/@kripa006/404-ui" target="_blank" rel="noopener" class="link-arrow">
                  npm
                </a>
              </li>
              <li><code class="code-inline text-[11px]">npm i @kripa006/404-ui</code></li>
              <li><code class="code-inline text-[11px]">pnpm add @kripa006/404-ui</code></li>
              <li><code class="code-inline text-[11px]">yarn add @kripa006/404-ui</code></li>
            </ul>
          </div>
        </div>

        <hr class="rule mt-14" />
        <div class="mt-6 flex flex-col items-start justify-between gap-2 text-[11px] text-paper-dim sm:flex-row sm:items-center">
          <p class="font-mono tracking-[0.15em]">
            MIT LICENSE · © {new Date().getFullYear()} · KRIPA SINDHU
          </p>
          <p class="font-mono tracking-[0.15em]">
            HANDCRAFTED · NOT AI-SLOP · <span class="text-accent">●</span> LIVE
          </p>
        </div>
      </div>
    </footer>

    <script is:inline>
      // Keep the site in the chosen dark palette regardless of system theme —
      // the editorial look is engineered for dark. (Toggle hook reserved for later.)
      document.documentElement.classList.add("dark");

      const copyBtn = document.getElementById("copy-install-nav");
      if (copyBtn) {
        copyBtn.addEventListener("click", async () => {
          try {
            await navigator.clipboard.writeText("npm install @kripa006/404-ui");
            const original = copyBtn.innerHTML;
            copyBtn.innerHTML = '<span class="text-accent">✓</span> <span>copied to clipboard</span>';
            setTimeout(() => {
              copyBtn.innerHTML = original;
            }, 1400);
          } catch {
            /* clipboard unavailable */
          }
        });
      }

      // ⌘⇧C copies install command
      document.addEventListener("keydown", (e) => {
        const mod = e.metaKey || e.ctrlKey;
        if (mod && e.shiftKey && (e.key === "c" || e.key === "C")) {
          e.preventDefault();
          copyBtn?.click();
        }
      });

      // Mobile menu toggle
      const menuToggle = document.getElementById("mobile-menu-toggle");
      const menuPanel = document.getElementById("mobile-menu");
      menuToggle?.addEventListener("click", () => {
        const open = menuPanel?.classList.toggle("hidden") === false;
        menuToggle.setAttribute("aria-expanded", open ? "true" : "false");
      });
      // Close the mobile menu when a link inside it is tapped
      menuPanel?.querySelectorAll("a").forEach((a) => {
        a.addEventListener("click", () => {
          menuPanel.classList.add("hidden");
          menuToggle?.setAttribute("aria-expanded", "false");
        });
      });
    </script>
  </body>
</html>

<style is:global>
  @import "@kripa006/404-ui/styles.css";
  @import "../styles/global.css";
</style>
